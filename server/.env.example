DATABASE_URL=postgresql://user:pass@localhost:5432/studentdb

# JWT_SECRET: Must be a cryptographically random string (64+ characters recommended).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_strong_random_secret_at_least_32_chars

# Client URL for CORS (include port if not 80/443)
CLIENT_URL=http://localhost:5173

# Cloudinary (optional, for production file storage)
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# Sentry DSN (optional, for error monitoring in production)
# Get from: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=

# Redis (optional, required for background jobs in production)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# SMTP (required for password reset emails in production)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Student Bio-Data Portal

# Server
PORT=4000
NODE_ENV=development
